# ============================================================
# Railway Environment Variables — скопируй в Railway Dashboard
# ============================================================

# PostgreSQL (Railway вставляет DATABASE_URL автоматически через Plugin)
DATABASE_URL=postgresql://user:password@host:5432/railway

# JWT (поменяй на случайную строку 32+ символов)
JWT_SECRET=change-this-to-a-random-secret-key-32chars

# ============================================================
# Cloudflare R2 (S3-совместимое хранилище)
# Dashboard: dash.cloudflare.com → R2 → API Tokens
# ============================================================
AWS_ACCESS_KEY_ID=your_r2_access_key_id
AWS_SECRET_ACCESS_KEY=your_r2_secret_access_key
AWS_REGION=auto

# R2 endpoint: https://<account_id>.r2.cloudflarestorage.com
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com

# Публичный URL бакета (R2 → Bucket → Public Access → Custom Domain или r2.dev)
# Пример: https://pub-HASH.r2.dev  или  https://assets.yourdomain.com
S3_PUBLIC_URL=https://pub-HASH.r2.dev
